# EmailJS configuration for the Contact page (public/src/pages/Contact.tsx).
#
# 1. Create a free account at https://www.emailjs.com
# 2. Add an Email Service (e.g. Gmail) and note its Service ID
# 3. Create an Email Template with variables:
#    from_name, from_email, institution, country, subject, message, to_email
#    and note its Template ID
# 4. Copy your Public Key from Account > General
# 5. Copy this file to `.env` and fill in the three values below
#
# If these are left unset, the Contact form still works: it gracefully
# falls back to opening a pre-filled mailto: link instead of failing.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
